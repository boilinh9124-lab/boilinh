---
import Layout from "../layouts/Layout.astro";
import TypewriterText from "../components/TypewriterText.jsx";

const links = [
  {
    name: "Bút Gel Mực Nước TakeNote (Set 36 Bút)",
    url: "https://shopee.vn/product/1366221078/26327704279?credential_token=8wEwiDL7YDtvaGuTQEQqFNFv6uhKz8Ro6UDFYJSwWx&exp_group=rollout&mmp_pid=an_17351310511&uls_trackid=55t26rrd00db&utm_campaign=id_zI0xmEhbgb&utm_content=----&utm_medium=affiliates&utm_source=an_17351310511&utm_term=f2qhm7ip9wq9",
    image: "/products/but-gel.png",
  },
  {
    name: "Má Hồng Kem OFÉLIA Lolli Liquid Blush (4.6g)",
    url: "https://shopee.vn/product/108276104/10859341175?credential_token=8wEwiDL7Xp1hYEkWSKVeJWwhL4DccaNFCAtWvYgijA&exp_group=rollout&mmp_pid=an_17351310511&uls_trackid=55t288nk01eg&utm_campaign=id_9GHQbTYf93&utm_content=----&utm_medium=affiliates&utm_source=an_17351310511&utm_term=f2qiowcm8cs9",
    image: "/products/ma-hong.png",
  },
  {
    name: "Phấn Bắt Sáng FLORTTE Glass Sea Series",
    url: "https://sl1nk.com/rdz66b5",
    image: "/products/phan-bat-sang.png",
  },
  {
    name: "Son Bóng 3D fwee Voluming Gloss (5.3g)",
    url: "https://sl1nk.com/n9yoeee",
    image: "/products/son-bong.png",
  },
  {
    name: "Má Hồng Kem AZTK",
    url: "https://sl1nk.com/cbn1ipn",
    image: "/products/ma-hong-aztk.png",
  },
  {
    name: "Kem Tạo Khối SHEGLAM",
    url: "https://l1nq.com/wgxgetz",
    image: "/products/kem-tao-khoi-sheglam.png",
  },
];
---

<Layout title="Cyn Review - Sản Phẩm Yêu Thích 💕">
  <main class="mt-6 mx-auto w-full max-w-lg px-4 pb-12">

    <!-- Header Section -->
    <header class="text-center mb-8 animate-fade-in">
      <!-- Profile Avatar -->
      <div class="flex justify-center mb-4">
        <div class="profile-ring">
          <img
            src="/portrait.webp"
            alt="Cyn Review Avatar"
            class="w-24 h-24 md:w-28 md:h-28 rounded-full object-cover"
            id="profile-avatar"
          />
        </div>
      </div>

      <!-- Shop Name -->
      <div class="flex items-center justify-center gap-1.5 mb-2">
        <h1 class="text-2xl md:text-3xl font-bold text-pastel-text tracking-tight">
          Cyn Review
        </h1>
        <!-- Verified Badge -->
        <svg class="w-5 h-5 mt-0.5" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" fill="#FF6B8A"/>
          <path d="M8 12.5l2.5 2.5L16 9.5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <!-- Description -->
      <p class="text-pastel-muted text-sm mb-2">
        Review & Chia sẻ sản phẩm yêu thích 💕
      </p>

      <!-- Typewriter -->
      <TypewriterText client:load />
    </header>

    <!-- Decorative Divider -->
    <div class="flex items-center justify-center gap-3 mb-6">
      <div class="h-px flex-1 bg-gradient-to-r from-transparent to-pastel-rose"></div>
      <span class="text-pastel-rose text-sm font-medium">✨ Sản phẩm nổi bật ✨</span>
      <div class="h-px flex-1 bg-gradient-to-l from-transparent to-pastel-rose"></div>
    </div>

    <!-- Product Links -->
    <div class="flex flex-col gap-3">
      {links.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="glass-card rounded-2xl overflow-hidden animate-stagger block"
        >
          <div class="flex items-center gap-3 p-2.5">
            <img
              src={link.image}
              alt={link.name}
              class="w-16 h-16 rounded-xl object-cover flex-shrink-0"
              loading="lazy"
            />
            <span class="text-sm font-semibold text-pastel-text leading-tight flex-1">
              {link.name}
            </span>
            <svg class="w-4 h-4 text-pastel-muted flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      ))}
    </div>

  </main>
</Layout>
